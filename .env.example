PORT=3001
PRODUCT_DATABASE_URL=postgresql://postgres.mavvvesnkbxdijdqlswo:@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
JWT_SECRET=change-me
EVOLUTION_API_BASE=http://194.164.77.139:8080
EVOLUTION_API_KEY=evolution_secure_key_2026_xyz
# Webhook applied automatically on instance create (POST /webhook/set + create body)
EVOLUTION_WEBHOOK_URL=https://your-n8n-or-bot.example.com/webhook/evolution
# Meta inbound: Nest verifies webhook + agent routing, then forwards raw Meta POST to n8n AI workflow
N8N_WHATSAPP_WEBHOOK_URL=https://your-n8n.example.com/webhook/whatsapp-ai
N8N_FORWARD_META_INBOUND=true
# Shared secret for n8n → Nest WhatsApp send (set same value in n8n env N8N_INTERNAL_API_KEY)
N8N_INTERNAL_API_KEY=change-me-n8n-internal-key
# Optional: n8n uses this as Nest API base for Meta sends (PUBLIC_API_BASE_URL also works)
# NEST_WHATSAPP_SEND_URL=https://api.yourdomain.com/v1/api
EVOLUTION_WEBHOOK_EVENTS=MESSAGES_UPSERT
EVOLUTION_WEBHOOK_BY_EVENTS=true
EVOLUTION_WEBHOOK_BASE64=false
# Instance settings on create + POST /settings/set (Evolution Manager toggles)
# true | false | 1 | 0 | yes | no — overridable per request via read_messages on POST /instance
EVOLUTION_READ_MESSAGES=true
EVOLUTION_ALWAYS_ONLINE=true
EVOLUTION_GROUPS_IGNORE=true
# Python Flask bot (AI chat, Pinecone sync, n8n webhooks) — Nest proxies /v1/api/bot/ai/* here
BOT_BASE_URL=http://localhost:5005

# Meta Facebook Page + Instagram (posts/images only — not messaging)
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:3001/v1/api/integrations/meta/callback
META_OAUTH_SUCCESS_REDIRECT=http://localhost:5173/settings
META_GRAPH_API_VERSION=v22.0
# Recommended: Facebook Login for Business configuration ID (Meta app → Facebook Login for Business → Configurations).
# When set, scope is NOT sent — permissions are defined in that configuration.
META_OAUTH_CONFIG_ID=
# Fallback when META_OAUTH_CONFIG_ID is empty (legacy Facebook Login only).
# instagram_basic is deprecated — use instagram_business_basic.
META_OAUTH_SCOPES=pages_show_list,pages_read_engagement,instagram_business_basic

AGENT_PENDING_TIMEOUT_HOURS=24
AGENT_ROUTING_CHECK_MINUTES=1

# Real-time agent inbox (optional — inbox also polls every 8s)
PUSHER_APP_ID=...
PUSHER_KEY=...
PUSHER_SECRET=...
PUSHER_CLUSTER=mt1

# Python bot: set BOT_SCHEDULER_ENABLED=0 on extra PM2 instances (only one worker should run cron)
# BOT_SCHEDULER_ENABLED=1

# Optional: public API URL for server-generated webhook links (frontend uses VITE_API_BASE_URL)
# PUBLIC_API_BASE_URL=https://api.yourdomain.com/v1/api